#!/usr/bin/env python3
"""
hazync — Proof Party contributor CLI.

  hazync id                 # create/show your signing identity (ed25519)
  hazync pick               # ask the coordinator for the next OPEN range (near the frontier)
  hazync claim <id>         # reserve an open range from the board (e.g. 0-999)
  hazync prove <id>         # prove that range on your GPU  -> a receipt .bin
  hazync submit <id>        # sign the receipt with your key and submit it for verification
  hazync run [id]           # claim + prove + submit, end to end (id optional: picks the next open range)

The party proves the chain forward from genesis, so you take a range near the current
frontier. The coordinator serves a ready-made witness bundle for each block in its window,
so you prove a block directly — no need to run your own node or replay the chain. An
arbitrary far-future block (past the served window) is not something a fresh contributor
can prove yet.

Config (env):
  COORD_URL   coordinator base URL   (default http://localhost:8899;
              the public party is https://bitcoinghost.org/hazync)
  HAZYNC_HOST path to the prover `host` binary (required for `prove`/`run`)
  BUNDLE_DIR  where fetched archive bundles live (default ~/.hazync/bundles)
  WITNESS_DIR legacy per-block witnesses, replay fallback (default ~/.hazync/witnesses)
Identity + receipts live under ~/.hazync/.
"""
import os, sys, json, base64, subprocess, urllib.request, urllib.error, pathlib, threading, time, shutil

HOME    = pathlib.Path(os.path.expanduser("~/.hazync"))
KEY     = HOME / "key.hex"
HANDLE  = HOME / "handle"
RCPTDIR = HOME / "receipts"
COORD   = os.environ.get("COORD_URL", "http://localhost:8899").rstrip("/")
HOSTBIN = os.environ.get("HAZYNC_HOST", "")
WITNESS = os.environ.get("WITNESS_DIR", str(HOME / "witnesses"))
BUNDLES = os.environ.get("BUNDLE_DIR", str(HOME / "bundles"))   # archive-node bundles fetched from the coordinator

def _ed():
    try:
        from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey
        from cryptography.hazmat.primitives import serialization
    except ImportError:
        sys.exit("missing the signing library `cryptography`. Install it:\n"
                 "  sudo apt install python3-cryptography      # Debian/Ubuntu\n"
                 "  or:  pip install cryptography")
    return Ed25519PrivateKey, serialization

def identity():
    HOME.mkdir(parents=True, exist_ok=True); RCPTDIR.mkdir(exist_ok=True)
    Ed25519PrivateKey, ser = _ed()
    if KEY.exists():
        sk = Ed25519PrivateKey.from_private_bytes(bytes.fromhex(KEY.read_text().strip()))
    else:
        sk = Ed25519PrivateKey.generate()
        KEY.write_text(sk.private_bytes(ser.Encoding.Raw, ser.PrivateFormat.Raw, ser.NoEncryption()).hex())
        KEY.chmod(0o600)
    pub = sk.public_key().public_bytes(ser.Encoding.Raw, ser.PublicFormat.Raw).hex()
    handle = HANDLE.read_text().strip() if HANDLE.exists() else ("ghost:" + pub[:6])
    return sk, pub, handle

def _open(req, timeout, tries=4):
    # Open a request with a timeout and retry on TRANSIENT network errors only — a real HTTP response
    # (4xx/5xx, incl. 409 already-claimed / 404 no-witness) is returned to the caller, never retried.
    # Without this a single flaky request hangs the whole CLI (the old no-timeout behaviour).
    for k in range(tries):
        try:
            return urllib.request.urlopen(req, timeout=timeout)
        except urllib.error.HTTPError:
            raise                                        # server answered — let the caller handle it
        except (urllib.error.URLError, OSError) as e:    # connection refused / reset / timeout
            if k + 1 >= tries:
                raise SystemExit(f"coordinator {COORD} unreachable after {tries} tries: {e}")
            time.sleep(2 * (k + 1))                       # 2s, 4s, 6s backoff

def post(path, body):
    req = urllib.request.Request(COORD + path, data=json.dumps(body).encode(),
        headers={"Content-Type": "application/json"})
    try:
        return json.load(_open(req, timeout=180))        # submit triggers verification — allow time
    except urllib.error.HTTPError as e:                  # coordinator returns JSON {"error": ...} with a 4xx/5xx
        try: return json.loads(e.read().decode())
        except Exception: raise SystemExit(f"coordinator error {e.code}: {e.reason}")

def get(path):
    return _open(urllib.request.Request(COORD + path), timeout=60).read()

def witness_in_window(blk):
    # True if the coordinator currently serves the witness for `blk` (i.e. the block is inside the rolling
    # window a fresh contributor can prove). A cheap pre-flight so `run` never claims a range it can't fetch.
    try:
        get(f"/api/witness/{blk}"); return True
    except urllib.error.HTTPError:
        return False

def fetch_witnesses(lo, hi):
    # the prover replays blocks 1..hi to rebuild the accumulator, so it needs every witness up to hi.
    # pull any we don't already have from the coordinator's rolling window.
    os.makedirs(WITNESS, exist_ok=True)
    for i in range(1, hi + 1):
        wf = os.path.join(WITNESS, f"block_{i}.json")
        if os.path.exists(wf):
            continue
        try:
            data = get(f"/api/witness/{i}")
        except Exception as e:
            sys.exit(f"could not fetch witness for block {i} from {COORD}: {e}")
        with open(wf, "wb") as fh:
            fh.write(data)

def fetch_bundles(lo, hi):
    # Fetch an archive-node bundle for every block in [lo..hi]. Returns True iff all are available (the
    # bridge path — prove with NO replay); False if any block is missing or only a legacy per-block witness
    # exists, in which case the caller falls back to the replay path. A bundle carries in_roots + witness.
    os.makedirs(BUNDLES, exist_ok=True)
    for h in range(lo, hi + 1):
        bf = os.path.join(BUNDLES, f"bundle_{h}.json")
        if os.path.exists(bf):
            continue
        try:
            data = get(f"/api/witness/{h}")
            j = json.loads(data)
        except Exception:
            return False
        if "in_roots" not in j or "witness" not in j:
            return False                       # legacy per-block witness, not a bridge bundle
        with open(bf, "wb") as fh:
            fh.write(data)
    return True

def parse_range(rng):
    # "N" -> (N, N); "lo-hi" -> (lo, hi). Exits with a clear message on anything else.
    try:
        p = [int(x) for x in rng.split("-")]
    except ValueError:
        p = []
    if len(p) == 1:
        return p[0], p[0]
    if len(p) == 2 and p[1] >= p[0]:
        return p[0], p[1]
    sys.exit(f"invalid range '{rng}' — use 'N' (one block) or 'lo-hi' (e.g. 1000-1999)")

def cmd_id(args):
    _, pub, handle = identity()
    if args: HANDLE.write_text(args[0]); handle = args[0]
    print("handle :", handle); print("pubkey :", pub); print("coord  :", COORD)
    print("(set a handle:  hazync id <name>)")

def cmd_pick(args):
    r = json.loads(get("/api/pick"))
    if r.get("range"):
        print("next open range:", r["range"], "  (claim it:  hazync run", r["range"] + ")")
    else:
        print(r.get("note", "nothing open"))
    return r.get("range")

def cmd_claim(args):
    rng = args[0]; _, pub, handle = identity()
    res = post("/api/claim", {"range": rng, "pubkey": pub, "handle": handle})
    if res.get("ok"):
        print(f"claimed {rng}"); return
    print(f"could not claim {rng}: {res.get('error') or res}"); sys.exit(1)

def _heartbeat(rng, pub, stop):
    # keep the claim alive while proving — ping the coordinator every 30s
    while not stop.wait(30):
        try: post("/api/heartbeat", {"range": rng, "pubkey": pub})
        except Exception: pass

def cmd_prove(args):
    rng = args[0]
    if not HOSTBIN or not os.path.exists(HOSTBIN):
        sys.exit("set HAZYNC_HOST to the prover `host` binary (needs a GPU box + witnesses in WITNESS_DIR)")
    _, pub, _ = identity()
    lo, hi = parse_range(rng)                            # "n" (single block) or "lo-hi" (range)
    RCPTDIR.mkdir(parents=True, exist_ok=True)
    out = RCPTDIR / f"{rng}.bin"
    # Prove + fold in a dedicated per-range work dir (under ~/.hazync) so the host's range_*.bin /
    # fold_*.bin intermediates never litter the CWD, never collide with a concurrent prove, and the final
    # os.replace stays on one filesystem (no EXDEV).
    work = RCPTDIR / f".work-{rng}"
    shutil.rmtree(work, ignore_errors=True); work.mkdir(parents=True, exist_ok=True)
    # Block 0 is the genesis anchor and is unprovable, so we start at max(lo, 1). The genesis-seed slot
    # 0-999 is thus proved as blocks 1..999; the coordinator (which pins the genesis in-boundary) accepts
    # a [1..hi] receipt for a [0..hi] claim. Starting at 1 also means a bad manual `run 0-...` no longer
    # crashes on `prove-range 0`.
    start = max(lo, 1)
    # Prefer the archive-node bridge: if the coordinator serves a ready-made bundle for every block in the
    # range, prove each with NO replay (O(1)/block). Otherwise fall back to the replay path, which rebuilds
    # the accumulator from genesis and so needs every witness up to hi.
    if fetch_bundles(start, hi):
        env = dict(os.environ, HAZYNC_BRIDGE_OUT=BUNDLES)
        prove_cmd = "prove-range-bridge"
        print(f"using archive-node bundles (no replay) for blocks {start}..{hi}")
    else:
        fetch_witnesses(start, hi)                    # pull any witnesses we're missing from the coordinator
        env = dict(os.environ, HAZYNC_WITNESS_DIR=WITNESS)
        prove_cmd = "prove-range"
        print(f"archive bundles unavailable — replaying from genesis for blocks {start}..{hi}")
    stop = threading.Event()
    threading.Thread(target=_heartbeat, args=(rng, pub, stop), daemon=True).start()  # keep the claim alive
    try:
        total = hi - start + 1
        print(f"proving range {rng} ({total} block{'s' if total != 1 else ''}) on your GPU — the expensive step; heartbeating the claim…")
        parts = []
        for i, h in enumerate(range(start, hi + 1), 1):
            # risc0 4.0.5 panics on ~10% of blocks (a preflight segment-boundary bug). Retry the block
            # with progressively smaller proving segments (HAZYNC_SEG_PO2 20->19->18); smaller segments
            # clear the boundary and the receipt is identical (guest unchanged), so it's transparent.
            for _po2 in (20, 19, 18):
                if subprocess.run([HOSTBIN, prove_cmd, str(h)],
                                  env=dict(env, HAZYNC_SEG_PO2=str(_po2)), cwd=work).returncode == 0:
                    break
            else:
                sys.exit(f"block {h} failed to prove even at reduced segment size (SEG_PO2=18)")
            parts.append(f"range_{h}.bin")
            if total > 1 and (i % 50 == 0 or i == total):
                print(f"  …proved {i}/{total} blocks — the board frontier advances once the whole range is proved + submitted", flush=True)
        _fold_and_save(parts, out, work)
        print("receipt:", out)
    finally:
        stop.set()
        shutil.rmtree(work, ignore_errors=True)          # drop the range_*/fold_* intermediates

def _fold_and_save(parts, out, work):
    # Recursively fold the per-block receipts into one; all I/O is inside `work` (cwd=work).
    rnd = 0
    while len(parts) > 1:
        rnd += 1
        nxt = []
        for i in range(0, len(parts), 2):
            if i + 1 < len(parts):
                m = f"fold_r{rnd}_{i}.bin"
                subprocess.run([HOSTBIN, "fold-range", parts[i], parts[i + 1], m], check=True, cwd=work)
                nxt.append(m)
            else:
                nxt.append(parts[i])
        print(f"  …folding into one receipt: {len(parts)} → {len(nxt)}", flush=True)
        parts = nxt
    os.replace(os.path.join(work, parts[0]), out)

def cmd_submit(args):
    rng = args[0]; sk, pub, handle = identity()
    f = RCPTDIR / f"{rng}.bin"
    if not f.exists(): sys.exit(f"no receipt at {f} — run `hazync prove {rng}` first")
    receipt = f.read_bytes()
    sig = sk.sign(receipt).hex()
    res = post("/api/submit", {"range": rng, "pubkey": pub, "handle": handle,
                               "sig": sig, "receipt": base64.b64encode(receipt).decode()})
    if res.get("ok"):
        print(f"✓ range {rng}: the coordinator re-verified your proof and put it on the board as '{handle}'.")
    else:
        print("✗ submit rejected:", res.get("error") or res)
    sys.exit(0 if res.get("ok") else 1)

def cmd_run(args):
    # Check the prover binary FIRST — `run` claims a range (locking it under the claim TTL), so we must
    # not claim only to bail later because HAZYNC_HOST is unset. (cmd_prove re-checks; this is the gate.)
    if not HOSTBIN or not os.path.exists(HOSTBIN):
        sys.exit("set HAZYNC_HOST to the prover `host` binary before `run` — download it from "
                 "https://github.com/bitcoin-ghost/hazync/releases/latest and `export HAZYNC_HOST=/path/to/host`.")
    if not args:                                     # no range given — let the coordinator pick one
        rng = cmd_pick([])
        if not rng: sys.exit("nothing open to claim")
        args = [rng]
    # Fail fast BEFORE claiming: the whole range must be inside the coordinator's served window. Probe both
    # ends (block 0 is unprovable, so clamp to 1) so a claim never locks a range we then can't fetch.
    lo, hi = parse_range(args[0])
    for probe in sorted({max(lo, 1), hi}):
        if not witness_in_window(probe):
            sys.exit(f"range {args[0]} is outside the coordinator's served window (block {probe} has no "
                     f"witness yet) — nothing was claimed. Pick an in-window range with `hazync pick`.")
    cmd_claim(args); cmd_prove(args); cmd_submit(args)

def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(__doc__); sys.exit(0 if argv else 1)   # explicit --help succeeds; a bare invocation is an error
    c, a = argv[0], argv[1:]
    fn = {"id": cmd_id, "pick": cmd_pick, "claim": cmd_claim, "prove": cmd_prove,
          "submit": cmd_submit, "run": cmd_run}.get(c)
    if not fn:
        print(f"unknown command '{c}'\n"); print(__doc__); sys.exit(1)
    if c in ("claim", "prove", "submit") and not a:  # these require a range; don't traceback on a bare call
        sys.exit(f"usage: hazync {c} <range>   (e.g. hazync {c} 1000-1999)")
    fn(a)

if __name__ == "__main__":
    main()
